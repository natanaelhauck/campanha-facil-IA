AI_PROVIDER=mock
AI_GENERATION_ENABLED=true
AI_REQUEST_TIMEOUT_MS=30000

AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_MAX_REQUESTS=10
AI_RATE_LIMIT_WINDOW_MS=60000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=4200

# Links públicos opcionais para validação beta (Google Forms, wa.me,
# formulário externo ou página de contato). Nunca coloque chaves aqui.
NEXT_PUBLIC_FEEDBACK_URL=
NEXT_PUBLIC_HELP_URL=

# Supabase opcional. Deixe desligado para modo visitante/localStorage.
# Use somente URL publica e anon key. Nao use service role no frontend.
NEXT_PUBLIC_SUPABASE_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
